# Usar a imagem oficial do Node.js (Slim para manter a imagem leve)
FROM node:22-slim

# Instalar dependências do sistema
RUN apt-get update && apt-get install -y \
    curl \
    git \
    jq \
    && rm -rf /var/lib/apt/lists/*

# Instalar o GitHub CLI (gh)
RUN type -p curl >/dev/null || (apt-get update && apt-get install curl -y) \
    && mkdir -p -m 755 /etc/apt/keyrings \
    && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | tee /etc/apt/keyrings/githubcli-archive-keyring.gpg > /dev/null \
    && chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update \
    && apt-get install gh -y

# Instalar o Gemini CLI globalmente
RUN npm install -g @google/gemini-cli

# Definir diretório de trabalho
WORKDIR /app

# Copiar os arquivos do projeto para o container
# O contexto de build será a raiz, então copiamos tudo para /app
COPY . .

# Garantir permissão de execução no script do worker (que agora está em .worker/)
RUN chmod +x .worker/agent-worker.sh

# O script precisa de configurações básicas do Git para realizar commits autônomos
RUN git config --global user.email "bot@iconit.com.br" \
    && git config --global user.name "DotAgents Worker" \
    && git config --global --add safe.directory /app

# Comando de entrada para rodar o worker apontando para o novo caminho
ENTRYPOINT ["./.worker/agent-worker.sh"]
